<Window x:Class="WindowsRoomReceiver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        Title="Cal Poly Room Audio" Height="780" Width="1220"
        Background="{StaticResource AppBackground}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="13" Foreground="{StaticResource BodyText}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ============= Header ============= -->
        <Border Grid.Row="0" Background="{StaticResource CalPolyGreen}" Padding="32,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Cal Poly Room Audio" Foreground="White"
                               FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="Secure Wi-Fi audio receiver"
                               Foreground="#C8DCD2" FontSize="12" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="HeaderConnectionText" Text="Not connected"
                               Foreground="#C8DCD2" VerticalAlignment="Center"
                               Margin="0,0,18,0"/>
                    <Button Content="Refresh Rooms" Click="RetryDiscovery_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent"
                                        BorderBrush="White" BorderThickness="1.5"
                                        CornerRadius="8" Padding="16,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      TextElement.Foreground="White"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#1E7B4F"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============= Body ============= -->
        <Grid Grid.Row="1" Margin="32,24,32,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- Rooms list -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Available Rooms"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource HeadingText}"/>
                        <TextBlock Text="Pair a room with its 6-digit PIN, then connect to begin streaming."
                                   Foreground="{StaticResource MutedText}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="#E6F0EB" CornerRadius="999"
                            Padding="14,6" VerticalAlignment="Center">
                        <TextBlock x:Name="RoomCountText" Text="0 rooms"
                                   Foreground="{StaticResource CalPolyGreen}"
                                   FontSize="12" FontWeight="SemiBold"/>
                    </Border>
                </Grid>

                <Border Grid.Row="1" Background="{StaticResource CardBackground}"
                        BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                        CornerRadius="14">
                    <Grid>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6">
                            <ItemsControl x:Name="RoomsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#E2E8E5" BorderThickness="0,0,0,1"
                                                Padding="20,18">
                                            <StackPanel>
                                                <!-- Header row -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Status pip -->
                                                    <Border Grid.Column="0" Width="10" Height="10"
                                                            CornerRadius="5" Margin="0,8,16,0"
                                                            VerticalAlignment="Top">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#9DB5AC"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding StatusText, Mode=OneWay}" Value="Connected">
                                                                        <Setter Property="Background" Value="#1E7B4F"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding StatusText, Mode=OneWay}" Value="Offline">
                                                                        <Setter Property="Background" Value="#B0322B"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>

                                                    <StackPanel Grid.Column="1">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding RoomName, Mode=OneWay}"
                                                                       FontSize="18" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource HeadingText}"/>
                                                            <Border Background="#E6F0EB" CornerRadius="999"
                                                                    Padding="8,2" Margin="10,3,0,0"
                                                                    VerticalAlignment="Center"
                                                                    Visibility="{Binding IsPaired, Mode=OneWay,
                                                                                 Converter={StaticResource BoolToVis}}">
                                                                <TextBlock Text="Paired" FontSize="11"
                                                                           Foreground="{StaticResource CalPolyGreen}"
                                                                           FontWeight="SemiBold"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Foreground="{StaticResource MutedText}" Margin="0,3,0,0">
                                                            <Run Text="{Binding StatusText, Mode=OneWay}"/>
                                                            <Run Text=" • "/>
                                                            <Run Text="{Binding CodecInfo, Mode=OneWay}"/>
                                                        </TextBlock>
                                                        <TextBlock Foreground="#7A8A85" FontSize="12" Margin="0,4,0,0">
                                                            <Run Text="Code"/>
                                                            <Run Text="{Binding RoomCode, Mode=OneWay}" FontWeight="SemiBold"/>
                                                            <Run Text=" • IP "/>
                                                            <Run Text="{Binding SourceIp, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                                VerticalAlignment="Center">
                                                        <!-- Pair: shown only when not paired -->
                                                        <Button Content="Pair" Click="Pair_Click"
                                                                Style="{StaticResource SecondaryButton}"
                                                                Visibility="{Binding IsPaired, Mode=OneWay,
                                                                             Converter={StaticResource BoolToVisInv}}"/>
                                                        <Button Content="Connect" Click="Connect_Click"
                                                                IsEnabled="{Binding IsPaired, Mode=OneWay}"/>
                                                        <Button Content="Identify" Click="Identify_Click"
                                                                Style="{StaticResource SecondaryButton}"
                                                                IsEnabled="{Binding IsPaired, Mode=OneWay}"/>
                                                        <Button Content="Forget" Click="Forget_Click"
                                                                Style="{StaticResource SecondaryButton}"
                                                                Visibility="{Binding IsPaired, Mode=OneWay,
                                                                             Converter={StaticResource BoolToVis}}"/>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Inline PIN entry: replaces the popup. Visible only
                                                     when this room is in pairing mode. -->
                                                <Border Background="#F2F7F4" CornerRadius="10" Padding="16,14"
                                                        Margin="26,14,0,0"
                                                        Visibility="{Binding IsPairing, Mode=OneWay,
                                                                     Converter={StaticResource BoolToVis}}">
                                                    <StackPanel>
                                                        <TextBlock Text="Enter the 6-digit PIN shown on the source Web UI"
                                                                   Foreground="{StaticResource HeadingText}"
                                                                   FontWeight="SemiBold"/>
                                                        <Grid Margin="0,10,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBox Grid.Column="0"
                                                                     Text="{Binding PinInput, Mode=TwoWay,
                                                                            UpdateSourceTrigger=PropertyChanged}"
                                                                     MaxLength="6" FontSize="18"
                                                                     Padding="10,8" VerticalContentAlignment="Center"
                                                                     HorizontalContentAlignment="Center"
                                                                     CharacterCasing="Upper"
                                                                     PreviewTextInput="PinBox_PreviewTextInput"/>
                                                            <Button Grid.Column="1" Content="Confirm"
                                                                    Click="PinConfirm_Click"
                                                                    Margin="10,0,0,0"
                                                                    IsDefault="True"/>
                                                            <Button Grid.Column="2" Content="Cancel"
                                                                    Click="PinCancel_Click"
                                                                    Style="{StaticResource SecondaryButton}"/>
                                                        </Grid>
                                                        <TextBlock Text="{Binding PairingStatus, Mode=OneWay}"
                                                                   Foreground="{StaticResource MutedText}"
                                                                   Margin="0,8,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <TextBlock x:Name="EmptyHint"
                                   Text="No rooms found yet.&#x0a;Make sure the source is powered on and joined to the same Wi-Fi as this PC."
                                   Foreground="{StaticResource MutedText}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   TextWrapping="Wrap" MaxWidth="420" TextAlignment="Center"
                                   Visibility="Visible"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Sidebar -->
            <StackPanel Grid.Column="1" Margin="24,0,0,0">

                <!-- Now Playing -->
                <Border Background="{StaticResource CardBackground}"
                        BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                        CornerRadius="14" Padding="22" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="NOW PLAYING" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedText}"
                                   Opacity="0.85"/>
                        <TextBlock x:Name="NowPlayingRoom" Text="Not connected"
                                   Margin="0,8,0,0" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource CalPolyGreen}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="NowPlayingDetails"
                                   Text="Connect to a paired room to begin streaming audio."
                                   Foreground="{StaticResource MutedText}" TextWrapping="Wrap"
                                   Margin="0,4,0,16"/>

                        <Grid Margin="0,4,0,12"
                              x:Name="NowPlayingMetricsGrid"
                              Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Packets" FontSize="11"
                                           Foreground="{StaticResource MutedText}"/>
                                <TextBlock x:Name="MetricPackets" Text="0"
                                           FontSize="18" FontWeight="SemiBold"
                                           Foreground="{StaticResource HeadingText}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Buffer" FontSize="11"
                                           Foreground="{StaticResource MutedText}"/>
                                <TextBlock x:Name="MetricBuffer" Text="—"
                                           FontSize="18" FontWeight="SemiBold"
                                           Foreground="{StaticResource HeadingText}"/>
                            </StackPanel>
                        </Grid>

                        <Button x:Name="DisconnectButton" Content="Disconnect"
                                Style="{StaticResource DangerButton}"
                                HorizontalAlignment="Stretch" Margin="0"
                                IsEnabled="False"
                                Click="Disconnect_Click"/>
                    </StackPanel>
                </Border>

                <!-- Audio Output -->
                <Border Background="{StaticResource CardBackground}"
                        BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                        CornerRadius="14" Padding="22">
                    <StackPanel>
                        <TextBlock Text="AUDIO OUTPUT" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedText}"
                                   Opacity="0.85"/>
                        <TextBlock Text="Choose the device with the lowest latency."
                                   Foreground="{StaticResource MutedText}" TextWrapping="Wrap"
                                   Margin="0,6,0,12"/>
                        <ComboBox x:Name="OutputDeviceCombo"
                                  DisplayMemberPath="Name"
                                  SelectionChanged="OutputDevice_SelectionChanged"/>
                        <TextBlock x:Name="OutputDeviceHint"
                                   Text="Applies the next time you connect to a room."
                                   Foreground="{StaticResource MutedText}" FontSize="12"
                                   TextWrapping="Wrap" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- ============= Footer ============= -->
        <Border Grid.Row="2" Background="White"
                BorderBrush="{StaticResource CardBorder}" BorderThickness="0,1,0,0"
                Padding="32,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Grid.Column="0"
                           Foreground="{StaticResource MutedText}"
                           Text="Looking for rooms on your network..."
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="Cal Poly Engineering • Room Audio v1.0"
                           Foreground="#9DB5AC" FontSize="11"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
