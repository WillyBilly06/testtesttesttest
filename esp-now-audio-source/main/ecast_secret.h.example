/*
 * ecast_secret.h — shared secret for EspCastBR encryption.
 *
 * *** IMPORTANT ***
 * ----------------
 *  1. Copy this file to `ecast_secret.h` in the SAME directory.
 *  2. Replace ECAST_BROADCAST_CODE_BYTES with a *private*, *random*,
 *     16-byte sequence. Example (run on a dev box):
 *
 *        python -c "import os; print(', '.join(f'0x{b:02X}' for b in os.urandom(16)))"
 *
 *  3. The SAME bytes must be present in the sink project's copy of
 *     ecast_secret.h. The shared secret is what gates who can decode
 *     your audio.
 *  4. `ecast_secret.h` is gitignored — DO NOT commit it.
 *  5. If someone recovers the firmware binary they can extract the key.
 *     For stronger tamper resistance use ESP32 flash encryption +
 *     secure boot + hide the constant in IRAM; outside the scope of
 *     this template.
 */

#pragma once

/* 16-byte Broadcast_Code — must match on source and sink. */
#define ECAST_BROADCAST_CODE_BYTES { \
    0xDE,0xAD,0xBE,0xEF,0xDE,0xAD,0xBE,0xEF, \
    0xDE,0xAD,0xBE,0xEF,0xDE,0xAD,0xBE,0xEF  \
}
